@page
@model SetPasswordModel
@{
    ViewData["Title"] = "Set password";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}

<h3><i class="fa-solid fa-lock me-2"></i>Set Password</h3>
<partial name="_StatusMessage" for="StatusMessage" />
<p class="tb-manage-warning"><i class="fa-solid fa-circle-info me-1"></i> You don't have a local password yet. Add one so you can log in directly.</p>
<form id="set-password-form" method="post" class="tb-manage-form">
    <div asp-validation-summary="ModelOnly" class="tb-status-error" role="alert"></div>
    <div class="tb-field-group">
        <label asp-for="Input.NewPassword" class="tb-field-label"><i class="fa-solid fa-key me-1"></i> New Password</label>
        <input asp-for="Input.NewPassword" class="tb-field-input" autocomplete="new-password" placeholder="Enter new password" />
        <span asp-validation-for="Input.NewPassword" class="tb-field-error"></span>
    </div>
    <div class="tb-field-group">
        <label asp-for="Input.ConfirmPassword" class="tb-field-label"><i class="fa-solid fa-key me-1"></i> Confirm Password</label>
        <input asp-for="Input.ConfirmPassword" class="tb-field-input" autocomplete="new-password" placeholder="Confirm new password" />
        <span asp-validation-for="Input.ConfirmPassword" class="tb-field-error"></span>
    </div>
    <button type="submit" class="tb-manage-btn">Set Password</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
