@model TravelBuddy.ViewModels.Excursion.DeleteExcursionViewModel

@{
    ViewData["Title"] = "Delete Excursion";
}

<section class="tb-page-hero">
    <div class="tb-page-hero-content">
        <h1><i class="fa-solid fa-trash me-2"></i>Delete Excursion</h1>
        <p>This action cannot be undone</p>
    </div>
</section>

<section class="tb-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-5">

                <div class="tb-privacy-card text-center">
                    <div style="font-size:3rem; color:#ef4444; margin-bottom:1rem;">
                        <i class="fa-solid fa-triangle-exclamation"></i>
                    </div>
                    <h4 style="font-family:'Montserrat',sans-serif; font-weight:800; color:var(--tb-dark);">
                        Are you sure?
                    </h4>
                    <p class="text-muted mb-1">You are about to permanently delete:</p>
                    <p style="font-size:1.1rem; font-weight:700; color:var(--tb-primary); margin-bottom:.25rem;">
                        @Model.Title
                    </p>
                    <p class="text-muted mb-4" style="font-size:.9rem;">
                        <i class="fa-solid fa-location-dot me-1"></i>@Model.Destination
                    </p>


                    <form asp-area="Admin" asp-controller="ExcursionManagement" asp-action="DeleteExcursion"
                          asp-route-excursionId="@Model.Id" method="post"
                          class="d-flex gap-3 justify-content-center flex-wrap">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="tb-btn-primary" style="background:#ef4444;">
                            <i class="fa-solid fa-trash me-2"></i>Yes, Delete
                        </button>
                        <a asp-area="Admin" asp-controller="ExcursionManagement" asp-action="Index"
                           class="tb-btn-primary" style="background:#6c757d;">
                            <i class="fa-solid fa-arrow-left me-2"></i>Cancel
                        </a>
                    </form>
                </div>

            </div>
        </div>
    </div>
</section>
