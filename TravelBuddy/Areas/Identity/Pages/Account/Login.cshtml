@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
}

<div class="tb-auth-wrapper">
    <div class="tb-auth-card">
        <div class="tb-auth-header">
            <div class="tb-auth-icon">
                <i class="fa-solid fa-plane-departure"></i>
            </div>
            <h1 class="tb-auth-title">Welcome Back</h1>
            <p class="tb-auth-subtitle">Log in to continue your journey with TravelBuddy</p>
        </div>

        <form id="account" method="post" class="tb-auth-form">
            <div asp-validation-summary="ModelOnly" class="tb-auth-alert" role="alert"></div>

            <div class="tb-field-group">
                <label asp-for="Input.Email" class="tb-field-label">
                    <i class="fa-solid fa-envelope me-1"></i> Email Address
                </label>
                <input asp-for="Input.Email" class="tb-field-input" autocomplete="username"
                       aria-required="true" placeholder="name@example.com" />
                <span asp-validation-for="Input.Email" class="tb-field-error"></span>
            </div>

            <div class="tb-field-group">
                <label asp-for="Input.Password" class="tb-field-label">
                    <i class="fa-solid fa-lock me-1"></i> Password
                </label>
                <input asp-for="Input.Password" class="tb-field-input" autocomplete="current-password"
                       aria-required="true" placeholder="Enter your password" />
                <span asp-validation-for="Input.Password" class="tb-field-error"></span>
            </div>

            <div class="d-flex align-items-center justify-content-between mb-4">
                <label class="tb-remember-label">
                    <input class="tb-remember-check" asp-for="Input.RememberMe" type="checkbox" />
                    <span>@Html.DisplayNameFor(m => m.Input.RememberMe)</span>
                </label>
            </div>

            <button id="login-submit" type="submit" class="tb-auth-btn">
                <i class="fa-solid fa-right-to-bracket me-2"></i>Log In
            </button>
        </form>
        <div class="tb-auth-footer">
            <p>New to TravelBuddy?
                <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Create an account</a>
            </p>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
