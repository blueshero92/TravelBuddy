<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TravelBuddy</title>
    <script type="importmap"></script>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@700;800&family=Poppins:wght@400;500;600&display=swap" rel="stylesheet" />

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" crossorigin="anonymous" />

    <link rel="icon" type="image/x-icon" href="~/favicon.ico" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TravelBuddy.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg tb-navbar">
            <div class="container-fluid px-lg-2 px-3">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="fa-solid fa-plane-departure me-2"></i>Travel<span>Buddy</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain"
                        aria-controls="navbarMain" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarMain">
                    <ul class="navbar-nav me-auto gap-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">
                                <i class="fa-solid fa-house me-1"></i>Home
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Privacy">
                                <i class="fa-solid fa-shield-halved me-1"></i>Privacy
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Excursion" asp-action="Index">
                                <i class="fa-solid fa-map-marked-alt me-1"></i>Destinations
                            </a>
                        </li>
                    </ul>

                    <div class="d-flex align-items-center gap-2 ms-lg-3">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                                @if (User.IsInRole("Admin"))
                                {
                                    <li class="nav-item">
                                        <a class="nav-link" asp-area="Admin" asp-controller="HomeAdmin" asp-action="Index"
                                           style="color:var(--tb-accent-lt) !important;">
                                            <i class="fa-solid fa-screwdriver-wrench me-1"></i>Control Panel
                                        </a>
                                    </li>
                                }
                                else
                                {
                                        <li class="nav-item">
                                            <a class="nav-link" asp-area="" asp-controller="Excursion" asp-action="MyFavoriteExcursions">
                                                <i class="fa-solid fa-heart me-1"></i>Favourites
                                            </a>
                                        </li>
                                        <li class="nav-item">
                                            <a class="nav-link" asp-area="" asp-controller="Booking" asp-action="MyBookings">
                                                <i class="fa-solid fa-suitcase-rolling me-1"></i>My Bookings
                                            </a>
                                        </li>
                                        <li class="nav-item">
                                            <a class="nav-link" asp-area="" asp-controller="CancellationRequest" asp-action="Index">
                                                <i class="fa-solid fa-file-circle-xmark me-1"></i>My Cancellation Requests
                                            </a>
                                        </li>
                                }
                        }
                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="tb-footer">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-4 col-md-6">
                    <div class="footer-brand mb-3">
                        <i class="fa-solid fa-plane-departure me-2"></i>Travel<span>Buddy</span>
                    </div>
                    <p>Your trusted partner for unforgettable travel experiences around the globe. Explore, discover, and create memories that last a lifetime.</p>
                </div>
                <div class="col-lg-2 col-md-6 col-6">
                    <h6>Quick Links</h6>
                    <ul>
                        <li><a asp-area="" asp-controller="Home" asp-action="Index">Home</a></li>
                        <li><a href="#">Destinations</a></li>
                        <li><a href="#">Tours</a></li>
                        <li><a href="#">About Us</a></li>
                        <li><a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a></li>
                    </ul>
                </div>
                <div class="col-lg-4 col-md-6">
                    <h6>Contact Us</h6>
                    <ul>
                        <li><i class="fa-solid fa-location-dot me-2 text-warning"></i>123 Explorer Ave, Travel City</li>
                        <li class="mt-2"><i class="fa-solid fa-phone me-2 text-warning"></i>+1 (800) TRAVEL-1</li>
                        <li class="mt-2"><i class="fa-solid fa-envelope me-2 text-warning"></i>hello@travelbuddy.com</li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="tb-footer-bottom">
            <div class="container d-flex flex-wrap justify-content-between align-items-center gap-2">
                <span>&copy; 2026 TravelBuddy. All rights reserved.</span>
                <span>
                    <a asp-area="" asp-controller="Home" asp-action="Privacy" class="text-decoration-none" style="color:inherit">Privacy Policy</a>
                </span>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
