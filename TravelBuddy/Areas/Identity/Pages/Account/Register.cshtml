@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

<div class="tb-auth-wrapper">
    <div class="tb-auth-card">

        <div class="tb-auth-header">
            <div class="tb-auth-icon">
                <i class="fa-solid fa-map-location-dot"></i>
            </div>
            <h1 class="tb-auth-title">Start Your Journey</h1>
            <p class="tb-auth-subtitle">Create your free TravelBuddy account today</p>
        </div>

        <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="tb-auth-form">
            <div asp-validation-summary="ModelOnly" class="tb-auth-alert" role="alert"></div>
          
            <div class="tb-field-group">
                <label asp-for="Input.Username" class="tb-field-label">
                    <i class="fa-solid fa-user me-1"></i> Username
                </label>
                <input asp-for="Input.Username" class="tb-field-input" autocomplete="username"
                       aria-required="true" placeholder="Enter your username" />
                <span asp-validation-for="Input.Username" class="tb-field-error"></span>
            </div>

            <div class="tb-field-group">
                <label asp-for="Input.Email" class="tb-field-label">
                    <i class="fa-solid fa-envelope me-1"></i> Email Address
                </label>
                <input asp-for="Input.Email" class="tb-field-input" autocomplete="username"
                       aria-required="true" placeholder="name@example.com" />
                <span asp-validation-for="Input.Email" class="tb-field-error"></span>
            </div>
            <div class="tb-field-group">
                <label asp-for="Input.FullName" class="tb-field-label">
                    <i class="fa-solid fa-user me-1"></i> Full Name
                </label>
                <input asp-for="Input.FullName" class="tb-field-input" autocomplete="name"
                       aria-required="true" placeholder="John Doe" />
                <span asp-validation-for="Input.FullName" class="tb-field-error"></span>
            </div>

            <div class="tb-field-group">
                <label asp-for="Input.Password" class="tb-field-label">
                    <i class="fa-solid fa-lock me-1"></i> Password
                </label>
                <input asp-for="Input.Password" class="tb-field-input" autocomplete="new-password"
                       aria-required="true" placeholder="Create a password" />
                <span asp-validation-for="Input.Password" class="tb-field-error"></span>
            </div>

            <div class="tb-field-group">
                <label asp-for="Input.ConfirmPassword" class="tb-field-label">
                    <i class="fa-solid fa-lock me-1"></i> Confirm Password
                </label>
                <input asp-for="Input.ConfirmPassword" class="tb-field-input" autocomplete="new-password"
                       aria-required="true" placeholder="Repeat your password" />
                <span asp-validation-for="Input.ConfirmPassword" class="tb-field-error"></span>
            </div>

            <button id="registerSubmit" type="submit" class="tb-auth-btn">
                <i class="fa-solid fa-user-plus me-2"></i>Create Account
            </button>
        </form>

        <div class="tb-auth-footer">
            <p>Already have an account?
                <a asp-page="./Login">Log in here</a>
            </p>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
