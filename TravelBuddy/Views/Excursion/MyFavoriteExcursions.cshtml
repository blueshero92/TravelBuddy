@model IEnumerable<TravelBuddy.ViewModels.Excursion.ExcursionViewModel>

@{
    ViewData["Title"] = "Favourites";
}

<section class="tb-page-hero">
    <div class="tb-page-hero-content">
        <h1><i class="fa-solid fa-heart me-2"></i>My Favourites</h1>
        <p>Excursions you have saved for later</p>
    </div>
</section>

<section class="tb-section">
    <div class="container">

        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <div style="font-size:3.5rem; color:var(--tb-accent); margin-bottom:1rem;">
                    <i class="fa-regular fa-heart"></i>
                </div>
                <h3 style="font-family:'Montserrat',sans-serif; font-weight:700; color:var(--tb-dark);">No favourites yet</h3>
                <p class="text-muted mb-4">Browse destinations and click the heart to save them here.</p>
                <a asp-controller="Excursion" asp-action="Index" class="tb-btn-primary">
                    <i class="fa-solid fa-compass me-2"></i>Browse Destinations
                </a>
            </div>
        }
        else
        {
            <div class="row g-4">
                @foreach (var excursion in Model)
                {
                    <div class="col-lg-4 col-md-6">
                        <div class="tb-dest-card card h-100">
                            <div class="card-img-wrapper position-relative">
                                <img src="@excursion.ImageUrl" class="card-img-top" alt="@excursion.Destination" />
                                <span class="tb-badge-dest">
                                    <i class="fa-solid fa-location-dot me-1"></i>@excursion.Destination
                                </span>
                            </div>
                            <div class="card-body d-flex flex-column">
                                <h5 class="card-title">@excursion.Title</h5>
                                <div class="d-flex gap-3 mb-2 text-muted" style="font-size:.88rem;">
                                    <span>
                                        <i class="fa-regular fa-calendar me-1"></i>
                                        @excursion.StartDate.ToString("MMM dd") – @excursion.EndDate.ToString("MMM dd, yyyy")
                                    </span>
                                </div>
                                <div class="d-flex gap-3 mb-3 text-muted" style="font-size:.88rem;">
                                    <span>
                                        <i class="fa-solid fa-users me-1"></i>@excursion.Capacity spots left
                                    </span>
                                </div>
                                <div class="mt-auto">
                                    <div class="mb-2">
                                        <span class="tb-price">
                                            $@excursion.Price.ToString("0.00")
                                            <small>/ person</small>
                                        </span>
                                    </div>
                                    <div class="d-flex gap-2">
                                        @if (User.Identity?.IsAuthenticated == true)
                                        {
                                            <form asp-controller="Excursion" asp-action="AddToFavorites" method="post">
                                                <input type="hidden" name="excursionId" value="@excursion.Id" />
                                                @Html.AntiForgeryToken()
                                                <button type="submit"
                                                        style="padding:.4rem .8rem; font-size:.82rem; width:95px; background:transparent; border:1.5px solid var(--tb-accent); color:var(--tb-accent); border-radius:6px; cursor:pointer; white-space:nowrap;"
                                                        title="Add to Favourites">
                                                    <i class="fa-regular fa-heart me-1"></i>Add
                                                </button>
                                            </form>
                                            <form asp-controller="Excursion" asp-action="RemoveFromFavorites" method="post">
                                                <input type="hidden" name="excursionId" value="@excursion.Id" />
                                                @Html.AntiForgeryToken()
                                                <button type="submit"
                                                        style="padding:.4rem .8rem; font-size:.82rem; width:95px; background:transparent; border:1.5px solid #dc3545; color:#dc3545; border-radius:6px; cursor:pointer; white-space:nowrap;"
                                                        title="Remove from Favourites">
                                                    <i class="fa-solid fa-heart-crack me-1"></i>Remove
                                                </button>
                                            </form>
                                        }
                                        <a asp-controller="Excursion" asp-action="Details" asp-route-id="@excursion.Id"
                                           class="tb-btn-primary" style="padding:.4rem .8rem; font-size:.82rem; white-space:nowrap;">
                                            View Details
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }

    </div>
</section>
