@page
@model ChangePasswordModel
@{
    ViewData["Title"] = "Change password";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}

<h3><i class="fa-solid fa-lock me-2"></i>Change Password</h3>
<partial name="_StatusMessage" for="StatusMessage" />
<form id="change-password-form" method="post" class="tb-manage-form">
    <div asp-validation-summary="ModelOnly" class="tb-status-error" role="alert"></div>
    <div class="tb-field-group">
        <label asp-for="Input.OldPassword" class="tb-field-label"><i class="fa-solid fa-lock me-1"></i> Current Password</label>
        <input asp-for="Input.OldPassword" class="tb-field-input" autocomplete="current-password" aria-required="true" placeholder="Enter current password" />
        <span asp-validation-for="Input.OldPassword" class="tb-field-error"></span>
    </div>
    <div class="tb-field-group">
        <label asp-for="Input.NewPassword" class="tb-field-label"><i class="fa-solid fa-key me-1"></i> New Password</label>
        <input asp-for="Input.NewPassword" class="tb-field-input" autocomplete="new-password" aria-required="true" placeholder="Enter new password" />
        <span asp-validation-for="Input.NewPassword" class="tb-field-error"></span>
    </div>
    <div class="tb-field-group">
        <label asp-for="Input.ConfirmPassword" class="tb-field-label"><i class="fa-solid fa-key me-1"></i> Confirm New Password</label>
        <input asp-for="Input.ConfirmPassword" class="tb-field-input" autocomplete="new-password" aria-required="true" placeholder="Confirm new password" />
        <span asp-validation-for="Input.ConfirmPassword" class="tb-field-error"></span>
    </div>
    <button type="submit" class="tb-manage-btn">Update Password</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
