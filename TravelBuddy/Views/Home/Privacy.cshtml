@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="tb-page-hero">
    <div class="tb-page-hero-content">
        <span class="tb-hero-eyebrow">Legal</span>
        <h1>Privacy Policy</h1>
        <p>How TravelBuddy collects, uses, and protects your information.</p>
    </div>
</div>

<div class="tb-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">

                <div class="tb-privacy-card">
                    <div class="tb-privacy-section">
                        <div class="tb-privacy-icon"><i class="fa-solid fa-circle-info"></i></div>
                        <div>
                            <h2>Overview</h2>
                            <p>At TravelBuddy, your privacy is important to us. This policy explains what personal data we collect when you use our platform and how we use it to deliver and improve our services. By using TravelBuddy, you agree to the practices described on this page.</p>
                        </div>
                    </div>
                </div>

                <div class="tb-privacy-card">
                    <div class="tb-privacy-section">
                        <div class="tb-privacy-icon"><i class="fa-solid fa-database"></i></div>
                        <div>
                            <h2>Information We Collect</h2>
                            <p>We may collect the following types of information:</p>
                            <ul class="tb-privacy-list">
                                <li><strong>Account information</strong> — name, email address, and password when you register.</li>
                                <li><strong>Booking details</strong> — travel dates, destination preferences, and passenger information.</li>
                                <li><strong>Usage data</strong> — pages visited, search queries, and interaction patterns to improve the experience.</li>
                                <li><strong>Device &amp; technical data</strong> — IP address, browser type, and operating system for security purposes.</li>
                            </ul>
                        </div>
                    </div>
                </div>

                <div class="tb-privacy-card">
                    <div class="tb-privacy-section">
                        <div class="tb-privacy-icon"><i class="fa-solid fa-gear"></i></div>
                        <div>
                            <h2>How We Use Your Information</h2>
                            <p>Your data is used solely to provide and improve TravelBuddy services:</p>
                            <ul class="tb-privacy-list">
                                <li>Process and manage your travel bookings.</li>
                                <li>Send booking confirmations and important travel updates.</li>
                                <li>Personalise destination recommendations.</li>
                                <li>Maintain the security and integrity of our platform.</li>
                                <li>Comply with applicable laws and regulations.</li>
                            </ul>
                        </div>
                    </div>
                </div>

                <div class="tb-privacy-card">
                    <div class="tb-privacy-section">
                        <div class="tb-privacy-icon"><i class="fa-solid fa-share-nodes"></i></div>
                        <div>
                            <h2>Sharing Your Information</h2>
                            <p>We do not sell your personal data to third parties. We may share information with trusted service providers (e.g. payment processors, airlines, hotels) strictly to fulfil your booking. All partners are contractually required to protect your data.</p>
                        </div>
                    </div>
                </div>

                <div class="tb-privacy-card">
                    <div class="tb-privacy-section">
                        <div class="tb-privacy-icon"><i class="fa-solid fa-shield-halved"></i></div>
                        <div>
                            <h2>Data Security</h2>
                            <p>We implement industry-standard security measures including HTTPS encryption, hashed passwords, and regular security audits to protect your information from unauthorised access or disclosure.</p>
                        </div>
                    </div>
                </div>

                <div class="tb-privacy-card">
                    <div class="tb-privacy-section">
                        <div class="tb-privacy-icon"><i class="fa-solid fa-user-check"></i></div>
                        <div>
                            <h2>Your Rights</h2>
                            <p>You have the right to:</p>
                            <ul class="tb-privacy-list">
                                <li>Access the personal data we hold about you.</li>
                                <li>Request correction of inaccurate information.</li>
                                <li>Request deletion of your account and associated data.</li>
                                <li>Withdraw consent for marketing communications at any time.</li>
                            </ul>
                            <p class="mt-3">To exercise any of these rights, contact us at <a href="mailto:privacy@travelbuddy.com">privacy@travelbuddy.com</a>.</p>
                        </div>
                    </div>
                </div>

                <div class="tb-privacy-card">
                    <div class="tb-privacy-section">
                        <div class="tb-privacy-icon"><i class="fa-solid fa-calendar-days"></i></div>
                        <div>
                            <h2>Policy Updates</h2>
                            <p>This policy may be updated periodically to reflect changes in our practices or applicable law. We will notify registered users of any significant changes via email. Continued use of TravelBuddy after updates constitutes acceptance of the revised policy.</p>
                            <p class="mt-2 text-muted" style="font-size:.88rem;"><em>Last updated: January 2026</em></p>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>
