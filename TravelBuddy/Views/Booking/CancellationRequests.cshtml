@model IEnumerable<TravelBuddy.ViewModels.BookingCancellationRequestViewModel>

@{
    ViewData["Title"] = "My Cancellation Requests";
}

<section class="tb-page-hero">
    <div class="tb-page-hero-content">
        <h1><i class="fa-solid fa-file-circle-xmark me-2"></i>My Cancellation Requests</h1>
        <p>Track all cancellation requests submitted for your bookings</p>
    </div>
</section>

<section class="tb-section">
    <div class="container">

        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <div style="font-size:3.5rem; color:var(--tb-accent); margin-bottom:1rem;">
                    <i class="fa-solid fa-inbox"></i>
                </div>
                <h3 style="font-family:'Montserrat',sans-serif; font-weight:700; color:var(--tb-dark);">
                    No cancellation requests yet
                </h3>
                <p class="text-muted mb-4">If you cancel a booking, the request will appear here.</p>
                <a asp-controller="Booking" asp-action="MyBookings" class="tb-btn-primary">
                    <i class="fa-solid fa-arrow-left me-2"></i>Back to My Bookings
                </a>
            </div>
        }
        else
        {
            <div class="row g-4">
                @foreach (var request in Model)
                {
                    string statusLabel = request.CancellationStatus == 0 ? "Pending"
                                       : request.CancellationStatus == 1 ? "Approved"
                                       : "Rejected";
                    string statusColor = request.CancellationStatus == 0 ? "var(--tb-accent)"
                                       : request.CancellationStatus == 1 ? "#22c55e"
                                       : "#ef4444";
                    string statusIcon = request.CancellationStatus == 0 ? "fa-clock"
                                      : request.CancellationStatus == 1 ? "fa-circle-check"
                                      : "fa-circle-xmark";
                    int duration = (request.ExcursionEndDate - request.ExcursionStartDate).Days;

                    <div class="col-md-6 col-lg-4">
                        <div class="tb-dest-card h-100" style="display:flex; flex-direction:column;">

                            <div style="position:relative; overflow:hidden; border-radius:16px 16px 0 0;">
                                <img src="@(request.ExcursionImageUrl ?? "https://images.unsplash.com/photo-1476514525535-07fb3b4ae5f1?w=900&auto=format&fit=crop")"
                                     alt="@request.ExcursionTitle"
                                     style="width:100%; height:190px; object-fit:cover; display:block;" />
                                <span style="position:absolute; top:.75rem; right:.75rem;
                                             background:@statusColor; color:#fff;
                                             padding:.25rem .75rem; border-radius:20px;
                                             font-size:.78rem; font-weight:700; letter-spacing:.5px;
                                             box-shadow:0 2px 8px rgba(0,0,0,.2);">
                                    <i class="fa-solid @statusIcon me-1"></i>@statusLabel
                                </span>
                            </div>

                            <div style="padding:1.25rem 1.5rem; flex:1; display:flex; flex-direction:column;">
                                <h5 style="font-family:'Montserrat',sans-serif; font-weight:800;
                                           color:var(--tb-dark); margin-bottom:.2rem;">
                                    @request.ExcursionTitle
                                </h5>
                                <p class="text-muted mb-3" style="font-size:.88rem;">
                                    <i class="fa-solid fa-location-dot me-1"></i>@request.ExcursionDestination
                                </p>

                                <ul class="tb-privacy-list" style="font-size:.88rem; margin-bottom:1rem;">
                                    <li>
                                        <i class="fa-regular fa-calendar me-2"></i>
                                        @request.ExcursionStartDate.ToString("MMM dd, yyyy") – @request.ExcursionEndDate.ToString("MMM dd, yyyy")
                                    </li>
                                    <li>
                                        <i class="fa-solid fa-hourglass-half me-2"></i>
                                        @duration day@(duration != 1 ? "s" : "")
                                    </li>
                                    <li>
                                        <i class="fa-solid fa-tag me-2"></i>
                                        <strong>$@request.ExcursionPrice.ToString("0.00")</strong>
                                    </li>
                                    <li>
                                        <i class="fa-regular fa-clock me-2"></i>
                                        Requested on @request.RequestedOn.ToString("MMM dd, yyyy")
                                    </li>
                                </ul>

                                @if (!string.IsNullOrWhiteSpace(request.Reason))
                                {
                                    <p class="text-muted mb-3" style="font-size:.85rem;">
                                        <i class="fa-regular fa-note-sticky me-1"></i>
                                        <strong>Reason:</strong> @request.Reason
                                    </p>
                                }

                                <div class="mt-auto d-flex flex-column gap-2">
                                    <a asp-controller="Excursion"
                                       asp-action="Details"
                                       asp-route-id="@request.ExcursionId"
                                       class="tb-btn-primary w-100 text-center"
                                       style="background:var(--tb-primary); font-size:.85rem;">
                                        <i class="fa-solid fa-circle-info me-1"></i>View Excursion
                                    </a>
                                </div>
                            </div>

                        </div>
                    </div>
                }
            </div>
        }

    </div>
</section>
